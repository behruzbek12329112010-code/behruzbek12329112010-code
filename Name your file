name: Generate Snake

on:
  schedule:
    # Har 12 soatda avtomatik ishga tushadi
    - cron: "0 */12 * * *"
  
  # Istalgan payt qo'lda ham ishga tushirish imkoniyati
  workflow_dispatch:
  
  push:
    branches:
    - BEXA
    - main
    - master

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - name: Clone repo
        uses: actions/checkout@v3

      - name: Generate the snake files
        uses: Platane/snk@v3
        with:
          github_user_name: ${{ github.repository_owner }}
          outputs: |
            dist/github-contribution-grid-snake.svg
            dist/github-contribution-grid-snake-dark.svg?palette=github-dark

      - name: Push the github-contribution-grid-snake.svg to the output branch
        uses: crazy-max/ghaction-github-pages@v3.1.0
        with:
          target_branch: output
          build_dir: dist
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
